// Função para criar matriz de risco
function riskBox(num, descricao, prob, impacto, materializacao, mitigacao, alocacao) {
  const boxBorder = { style: BorderStyle.SINGLE, size: 4, color: "555555" };
  const boxBorders = { top: boxBorder, bottom: boxBorder, left: boxBorder, right: boxBorder };
  const cell = (children, opts = {}) => new TableCell({
    borders: boxBorders,
    width: { size: opts.width || 4500, type: WidthType.DXA },
    shading: opts.header ? { fill: "BFBFBF", type: ShadingType.CLEAR } : (opts.subhead ? { fill: "E7E6E6", type: ShadingType.CLEAR } : undefined),
    margins: { top: 80, bottom: 80, left: 120, right: 120 },
    children: children
  });
  const para = (text, opts = {}) => new Paragraph({
    alignment: opts.align || AlignmentType.LEFT,
    children: [new TextRun({ text, bold: !!opts.bold, size: 20 })]
  });

  return new Table({
    width: { size: 9000, type: WidthType.DXA },
    columnWidths: [2200, 6800],
    rows: [
      new TableRow({
        children: [
          new TableCell({
            borders: boxBorders, width: { size: 9000, type: WidthType.DXA },
            shading: { fill: "BFBFBF", type: ShadingType.CLEAR },
            columnSpan: 2,
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para(`RISCO ${num}`, { bold: true, align: AlignmentType.CENTER })]
          })
        ]
      }),
      new TableRow({
        children: [
          cell([para("Descrição:", { bold: true })], { width: 2200 }),
          cell([para(descricao)], { width: 6800 })
        ]
      }),
      new TableRow({
        children: [
          cell([para("Probabilidade:", { bold: true })], { width: 2200 }),
          cell([para(prob)], { width: 6800 })
        ]
      }),
      new TableRow({
        children: [
          cell([para("Impacto:", { bold: true })], { width: 2200 }),
          cell([para(impacto)], { width: 6800 })
        ]
      }),
      new TableRow({
        children: [
          new TableCell({
            borders: boxBorders, width: { size: 9000, type: WidthType.DXA },
            shading: { fill: "E7E6E6", type: ShadingType.CLEAR },
            columnSpan: 2,
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para("Materialização (consequência se o risco ocorrer)", { bold: true })]
          })
        ]
      }),
      new TableRow({
        children: [
          new TableCell({
            borders: boxBorders, width: { size: 9000, type: WidthType.DXA },
            columnSpan: 2,
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para(materializacao)]
          })
        ]
      }),
      new TableRow({
        children: [
          new TableCell({
            borders: boxBorders, width: { size: 6300, type: WidthType.DXA },
            shading: { fill: "E7E6E6", type: ShadingType.CLEAR },
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para("Ação de mitigação (prevenção)", { bold: true })]
          }),
          new TableCell({
            borders: boxBorders, width: { size: 2700, type: WidthType.DXA },
            shading: { fill: "E7E6E6", type: ShadingType.CLEAR },
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para("Alocação", { bold: true, align: AlignmentType.CENTER })]
          })
        ]
      }),
      new TableRow({
        children: [
          new TableCell({
            borders: boxBorders, width: { size: 6300, type: WidthType.DXA },
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para(mitigacao)]
          }),
          new TableCell({
            borders: boxBorders, width: { size: 2700, type: WidthType.DXA },
            margins: { top: 80, bottom: 80, left: 120, right: 120 },
            children: [para(alocacao, { align: AlignmentType.CENTER, bold: true })]
          })
        ]
      }),
    ]
  });
}

