children.push(Item("4.9", "Assinatura Digital e Coleta de Evidências Biométricas: a solução deve possuir funcionalidade nativa para assinatura eletrônica de documentos (ASO, PGR, PCMSO, etc.) utilizando:"));
children.push(SubItem("4.9.1", "Certificado Digital (e-CPF/e-CNPJ padrão ICP-Brasil);"));
